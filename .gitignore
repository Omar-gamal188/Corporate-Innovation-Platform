# Dependencies
node_modules/
**/node_modules/

# Environment secrets — never commit real .env files
.env
.env.local
.env.*.local
**/.env
!**/.env.example

# Build output
dist/
dist-ssr/
build/
**/dist/
**/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Uploaded user content
server/uploads/*
!server/uploads/.gitkeep

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.local
.cache/
